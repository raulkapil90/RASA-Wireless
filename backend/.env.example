# ─── Cisco Catalyst Center (CCC) Integration ───────────────────────────────
# Set these to connect to a live CCC instance.
# Leave blank to run in DEMO mode with sample data locally or in production.
CCC_BASE_URL=
CCC_USERNAME=
CCC_PASSWORD=
CCC_VERIFY_SSL=true

# Webhook HMAC secret (optional — for validating inbound CCC event webhooks)
CCC_WEBHOOK_SECRET=

# ─── API Keys for Multi-LLM Consensus (Optional but Recommended) ─────────────
# Used for the Log Analysis consensus engine
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Jira Cloud Integration (Optional) ───────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NETOPS

# ─── Salesforce Integration (Optional) ───────────────────────────────────────
SF_LOGIN_URL=https://login.salesforce.com
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# ─── App Configuration ───────────────────────────────────────────────────────
# Define the environment mode (production, development)
ENVIRONMENT=production
