# ─── Cisco Catalyst Center (CCC) Integration ───────────────────────────────
# Set these to connect to a live CCC instance.
# Leave blank to run in DEMO mode with sample data.

CCC_BASE_URL=https://your-catalyst-center.example.com
CCC_USERNAME=admin
CCC_PASSWORD=
CCC_VERIFY_SSL=true

# Webhook HMAC secret (optional — for validating inbound CCC event webhooks)
CCC_WEBHOOK_SECRET=

# ─── Vercel / Frontend ────────────────────────────────────────────────────
# For local dev:
# VITE_API_BASE_URL=http://localhost:8000
# For Production (Railway Deployment):
# VITE_API_BASE_URL=https://your-railway-app.railway.app

# ─── Jira Cloud Integration ───────────────────────────────────────────────
# Get your API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NETOPS

# ─── Salesforce Integration ───────────────────────────────────────────────
# Use a Connected App with OAuth 2.0 Username-Password flow.
# Append your security token to the password: SF_PASSWORD=MyPass + SF_SECURITY_TOKEN=abc123
SF_LOGIN_URL=https://login.salesforce.com
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=


RASA_API_KEY=your-secure-api-key-here
